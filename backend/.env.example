# ============================================
# PULSO MUSICAL — Environment Configuration
# ============================================
# Copy this file to .env and fill with your values

# Database (PostgreSQL - Railway recommended)
DATABASE_URL="postgresql://user:password@localhost:5432/pulso_musical"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-change-in-production"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3000"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,https://pulsomusical.com.br"

# Email Service (SMTP - Gmail, SendGrid, etc)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu@email.com"
SMTP_PASS="sua-senha-smtp"
EMAIL_FROM="Pulso Musical <noreply@pulsomusical.com>"

# Alternative: SendGrid
#SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#SENDGRID_FROM_EMAIL="noreply@pulsomusical.com.br"

# Google OAuth (Calendar Sync)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/google/callback"

# Encryption (for sensitive data like Google tokens)
ENCRYPTION_KEY="32-chars-hex-encryption-key-here"

# AWS S3 (for file uploads - contracts, profiles, etc)
# AWS_ACCESS_KEY_ID="your_access_key"
# AWS_SECRET_ACCESS_KEY="your_secret_key"
# AWS_S3_BUCKET="pulso-musical-bucket"
# AWS_S3_REGION="sa-east-1"

# Stripe (Payments - Future Implementation)
# STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# STRIPE_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Uber API (Logistics Distance Estimation)
# UBER_API_KEY="your_uber_api_key_here"

# Redis (Caching & Session Storage)
# REDIS_URL="redis://localhost:6379"

# Logging
LOG_LEVEL="debug"

# ============================================
# Production Deployment Notes
# ============================================
# When deploying to Railway:
# 1. DATABASE_URL is provided automatically
# 2. Update JWT_SECRET with a strong random string
# 3. Set NODE_ENV=production
# 4. Configure actual API keys for email, Google, AWS, etc
# 5. Use HTTPS in FRONTEND_URL and callbacks
# ============================================
